sou.edu/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home"}]},{"@type":"WebSite","@id":"https://sou.edu/#website","url":"https://sou.edu/","name":"Southern Oregon University","description":"Southern Oregon University in Ashland, Oregon","publisher":{"@id":"https://sou.edu/#organization"},"alternateName":"SOU","potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://sou.edu/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://sou.edu/#organization","name":"Southern Oregon University","alternateName":"SOU Ashland","url":"https://sou.edu/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://sou.edu/#/schema/logo/image/","url":"https://sou.edu/wp-content/uploads/2022/01/SOU-LOGO-HZ-CMY-POS-scaled.jpg","contentUrl":"https://sou.edu/wp-content/uploads/2022/01/SOU-LOGO-HZ-CMY-POS-scaled.jpg","width":2560,"height":621,"caption":"Southern Oregon University"},"image":{"@id":"https://sou.edu/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/SOUAshland/","https://x.com/souashland","https://www.instagram.com/souashland/","https://www.linkedin.com/school/southern-oregon-university/","https://www.youtube.com/user/SouthernOregonUniv"],"description":"Southern Oregon University - SOU - is a Liberal Arts University in Ashland, Oregon. Serving the Southern Oregon and Northern California regions, SOU provides offers many higher education degree pathways, including: Major degree Undergraduate programs, Masters degree Graduate programs, Minor degrees, Certificate programs, and Micro-credential pathways. Southern Oregon University also provides Summer Youth Programs for students in the region from K-12, as well as continuing education programs through the Osher Lifelong Learning Institute (OLLI). Southern Oregon University welcomes students from abroad through SOU's International Programs, which also provides current SOU students opportunities to study away across the country and internationally through a multitude of partner universities. The beautiful SOU campus, nestled in the hills of Ashland, OR welcomes the surrounding community to come and enjoy many hosted events, including: sporting events at the SOU Raider Stadium and Lithia Motors Pavilion, theater performances hosted by the SOU Theatre program , musical performances at the SOU Musical Recital Hall, and art exhibitions at the Schneider Museum of Art and other campus art galleries. Southern Oregon University has many specialized programs which help lower tuition costs, grant in-state tuition, provide accelerated graduation, give opportunities to adult learners, and allow students to graduate with internships leading to job placement.","email":"admissions@sou.edu","telephone":"541-552-7672","legalName":"Southern Oregon University","foundingDate":"1872-09-01"},{"@type":"Person","@id":"https://sou.edu/#/schema/person/d63857b3b310cf49180208a32b86d2bc","name":"Sean Glassford","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://sou.edu/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/9d06c0ea896caf32907bcbdeae4e268bf90877fa2c09e7f919bd803e87634d1d?s=96&d=mm&r=g","contentUrl":"https://secure.gravatar.com/avatar/9d06c0ea896caf32907bcbdeae4e268bf90877fa2c09e7f919bd803e87634d1d?s=96&d=mm&r=g","caption":"Sean Glassford"}}]}</script>
